# --- Dependencies ---
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/releases
!.yarn/plugins
!.yarn/versions

# --- Build output ---
dist/
dist-ssr/
build/
out/
*.local

# --- Vite / bundler cache ---
.vite/
.cache/
*.tsbuildinfo

# --- Tests / coverage ---
coverage/
playwright-report/
test-results/
.nyc_output/

# --- Spikes / prototypes (local only; deps installed with `npm i --no-save`) ---
spike/

# --- Logs ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Environment / secrets ---
.env
.env.*
!.env.example
# License-signing private key MUST never be committed (see docs/product/monetization.md)
*.pem
*.key
secrets/

# --- Large local engine/model caches (fetched at runtime, never committed) ---
/models/
*.weights
*.onnx
# Vendored ffmpeg.wasm cores, copied from node_modules by scripts/copy-ffmpeg-core.mjs
public/ffmpeg/

# --- Editors / OS ---
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
