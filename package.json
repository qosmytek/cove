{
  "name": "cove",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "description": "Cove — on-device video compressor (WebCodecs + ffmpeg.wasm fallback).",
  "scripts": {
    "copy-core": "node scripts/copy-ffmpeg-core.mjs",
    "predev": "npm run copy-core",
    "dev": "vite",
    "prebuild": "npm run copy-core",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "test": "vitest run",
    "size": "size-limit",
    "e2e": "playwright test",
    "lhci": "lhci autorun"
  },
  "dependencies": {
    "@ffmpeg/core": "^0.12.6",
    "@ffmpeg/core-mt": "^0.12.6",
    "@ffmpeg/ffmpeg": "^0.12.10",
    "@ffmpeg/util": "^0.12.1",
    "mp4-muxer": "^5.2.2",
    "mp4box": "^2.3.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@biomejs/biome": "^2.4.16",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.60.0",
    "@size-limit/file": "^12.1.0",
    "size-limit": "^12.1.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^4.1.8"
  }
}
