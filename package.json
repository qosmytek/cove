{
  "name": "cove",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Cove — Phase 0 video-compressor spike (ffmpeg.wasm on-device).",
  "scripts": {
    "copy-core": "node scripts/copy-ffmpeg-core.mjs",
    "predev": "npm run copy-core",
    "dev": "vite",
    "prebuild": "npm run copy-core",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ffmpeg/core": "^0.12.6",
    "@ffmpeg/core-mt": "^0.12.6",
    "@ffmpeg/ffmpeg": "^0.12.10",
    "@ffmpeg/util": "^0.12.1",
    "mp4-muxer": "^5.2.2",
    "mp4box": "^2.3.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  }
}
